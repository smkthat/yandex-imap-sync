# Mail sync configuration for Yandex Mail / Yandex 360.
#
# Supported mailbox types:
# - login: a regular mailbox. IMAP login is the email address.
# - shared: a Yandex 360 shared mailbox. IMAP login is built as:
#   domain/delegate_login/shared_mailbox_name

# IMAP server for both source and target mailboxes.
# Default in the script: imap.yandex.ru
YANDEX_IMAP_SERVER=imap.yandex.ru

# imapsync options.
# Common modes:
# - --justlogin: check both logins only.
# - --dry --justfolders --automap --useheader Message-Id --errorsmax 5: dry-run folder check.
# - --automap --useheader Message-Id --errorsmax 5: full migration.
PARAMS=--automap --useheader Message-Id --errorsmax 5

# Source mailbox type: login or shared.
SOURCE_MAILBOX_TYPE=login

# Source regular mailbox login.
# Required when SOURCE_MAILBOX_TYPE=login.
SOURCE_IMAP_LOGIN=source@example.com

# Source mailbox app password.
# Required for both SOURCE_MAILBOX_TYPE=login and SOURCE_MAILBOX_TYPE=shared.
# For shared mode, this is the delegate employee app password.
SOURCE_IMAP_APP_PASSWORD=your_source_app_password_here

# Source shared mailbox domain.
# Required when SOURCE_MAILBOX_TYPE=shared.
# Example for info@example.org: example.org
# SOURCE_SHARED_MAILBOX_DOMAIN=example.org

# Source shared mailbox name before @.
# Required when SOURCE_MAILBOX_TYPE=shared.
# Example for info@example.org: info
# SOURCE_SHARED_MAILBOX_NAME=info

# Source delegate employee login with access to the shared mailbox.
# Required when SOURCE_MAILBOX_TYPE=shared.
# Can be a short login or full email; the script uses the part before @.
# SOURCE_DELEGATE_LOGIN=john.doe

# Target mailbox type: login or shared.
TARGET_MAILBOX_TYPE=shared

# Target regular mailbox login.
# Required when TARGET_MAILBOX_TYPE=login.
# TARGET_IMAP_LOGIN=info@example.org

# Target mailbox app password.
# Required for both TARGET_MAILBOX_TYPE=login and TARGET_MAILBOX_TYPE=shared.
# For shared mode, this is the delegate employee app password.
TARGET_IMAP_APP_PASSWORD=your_target_app_password_here

# Target shared mailbox domain.
# Required when TARGET_MAILBOX_TYPE=shared.
# Example for info@example.org: example.org
TARGET_SHARED_MAILBOX_DOMAIN=example.org

# Target shared mailbox name before @.
# Required when TARGET_MAILBOX_TYPE=shared.
# Example for info@example.org: info
TARGET_SHARED_MAILBOX_NAME=info

# Target delegate employee login with access to the shared mailbox.
# Required when TARGET_MAILBOX_TYPE=shared.
# Can be a short login or full email; the script uses the part before @.
TARGET_DELEGATE_LOGIN=john.doe
